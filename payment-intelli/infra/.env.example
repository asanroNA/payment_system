# Optional local overrides for infra/docker-compose.yml.
# The compose file has sane ${VAR:-default} fallbacks, so this file is NOT required to run.
# To use it:  cp infra/.env.example infra/.env  then  docker compose --env-file infra/.env ...
# Never commit a real infra/.env. Secrets come from the environment (Secrets Manager on AWS).

POSTGRES_USER=intellipay
POSTGRES_PASSWORD=intellipay
POSTGRES_DB=intellipay
